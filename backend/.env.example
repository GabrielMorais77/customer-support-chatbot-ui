APP_NAME="Customer Support API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Sao_Paulo
APP_URL=http://localhost:8000

FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/customer-support-chatbot-ui/backend/database/database.sqlite
DB_FOREIGN_KEYS=true

CACHE_STORE=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
BCRYPT_ROUNDS=12
